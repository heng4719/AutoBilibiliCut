<UserControl x:Class="videoCut.Views.CutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:videoCut.Models"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="18"
                             Height="18"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center">
                        <Grid Width="18" Height="18">
                            <Rectangle Margin="2,2,2,2"
                                       RadiusX="2"
                                       RadiusY="2"
                                       Stroke="{StaticResource PrimaryBrush}"
                                       StrokeThickness="1.4" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="4,4,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="4,8,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="4,12,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="0,4,4,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="0,8,4,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Margin="0,12,4,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Text="视频切片"
                               FontSize="22"
                               FontWeight="Bold" />
                </StackPanel>
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="选择本地视频后，查看基础信息并配置多个切片任务。" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom">
                <Button Content="选择视频"
                        Width="118"
                        Command="{Binding SelectVideoCommand}" />
                <Button Content="清空"
                        Width="92"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding ClearVideoCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,1"
                Padding="0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.ColumnSpan="4"
                            Orientation="Horizontal">
                    <Viewbox Width="15"
                             Height="15"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Grid Width="15" Height="15">
                            <Ellipse Margin="1.2"
                                     Stroke="{StaticResource PrimaryBrush}"
                                     StrokeThickness="1.2" />
                            <Rectangle Width="1.6"
                                       Height="5.2"
                                       RadiusX="0.8"
                                       RadiusY="0.8"
                                       Fill="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Margin="0,2.4,0,0" />
                            <Ellipse Width="1.8"
                                     Height="1.8"
                                     Fill="{StaticResource PrimaryBrush}"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Center"
                                     Margin="0,3.1,0,0" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               Text="视频信息" />
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="4"
                        Margin="0,0,0,10"
                        Padding="10,8"
                        Background="{StaticResource MutedSurfaceBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1">
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                               Text="{Binding VideoStatus}" />
                </Border>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="文件名" />
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding VideoName}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="文件大小" />
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding VideoSize}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="视频时长" />
                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding VideoDuration}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="3">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="文件路径" />
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Text="{Binding VideoPath}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.ColumnSpan="4"
                        Orientation="Horizontal">
                <Viewbox Width="15"
                         Height="15"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Grid Width="15" Height="15">
                        <Rectangle Margin="1.5"
                                   RadiusX="2"
                                   RadiusY="2"
                                   Stroke="{StaticResource PrimaryBrush}"
                                   StrokeThickness="1.2" />
                        <Path Data="M7.5,4 L7.5,11 M4,7.5 L11,7.5"
                              Stroke="{StaticResource PrimaryBrush}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Grid>
                </Viewbox>
                <TextBlock Style="{StaticResource SectionTitleStyle}"
                           Margin="0"
                           Text="新增切片" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="4"
                       Margin="0,0,0,8"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="请先选择视频，再添加切片时间范围。">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelectedVideo}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0"
                        IsEnabled="{Binding HasSelectedVideo}">
                <TextBlock Style="{StaticResource LabelStyle}" Text="切片名称" />
                <TextBox Text="{Binding NewSegmentName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,12,0"
                        IsEnabled="{Binding HasSelectedVideo}">
                <TextBlock Style="{StaticResource LabelStyle}" Text="开始时间" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="StartHourComboBox"
                              Grid.Column="0"
                              ItemsSource="{Binding HourOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentStartHour, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="StartMinuteComboBox"
                              Grid.Column="2"
                              ItemsSource="{Binding MinuteSecondOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentStartMinute, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="StartSecondComboBox"
                              Grid.Column="4"
                              ItemsSource="{Binding MinuteSecondOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentStartSecond, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,12,0"
                        IsEnabled="{Binding HasSelectedVideo}">
                <TextBlock Style="{StaticResource LabelStyle}" Text="结束时间" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="EndHourComboBox"
                              Grid.Column="0"
                              ItemsSource="{Binding HourOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentEndHour, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="EndMinuteComboBox"
                              Grid.Column="2"
                              ItemsSource="{Binding MinuteSecondOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentEndMinute, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox x:Name="EndSecondComboBox"
                              Grid.Column="4"
                              ItemsSource="{Binding MinuteSecondOptions}"
                              PreviewTextInput="NumericComboBox_PreviewTextInput"
                              PreviewKeyDown="NumericComboBox_PreviewKeyDown"
                              Text="{Binding NewSegmentEndSecond, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,8">
                <Button Content="加入列表"
                        Width="110"
                        IsEnabled="{Binding HasSelectedVideo}"
                        Command="{Binding AddSegmentCommand}" />
                <Button Content="清空列表"
                        Width="110"
                        Style="{StaticResource GhostButtonStyle}"
                        Command="{Binding ClearSegmentsCommand}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Viewbox Width="15"
                             Height="15"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Grid Width="15" Height="15">
                            <Rectangle Width="2.4"
                                       Height="2.4"
                                       Margin="2,2.2,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2.4"
                                       Height="2.4"
                                       Margin="2,6.3,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Width="2.4"
                                       Height="2.4"
                                       Margin="2,10.4,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Height="1.4"
                                       Margin="6.4,2.7,1.8,0"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Height="1.4"
                                       Margin="6.4,6.8,1.8,0"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                            <Rectangle Height="1.4"
                                       Margin="6.4,10.9,1.8,0"
                                       VerticalAlignment="Top"
                                       Fill="{StaticResource PrimaryBrush}" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               Text="切片列表" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="时间格式：mm:ss 或 hh:mm:ss" />
            </DockPanel>

            <DataGrid Grid.Row="1"
                      Background="{StaticResource SurfaceBrush}"
                      ItemsSource="{Binding Segments}"
                      IsReadOnly="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2*"
                                        Header="切片名称"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Width="*"
                                        Header="开始时间"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        Binding="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Width="*"
                                        Header="结束时间"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        EditingElementStyle="{StaticResource DataGridEditingTextStyle}"
                                        Binding="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Width="*"
                                        Header="预计时长"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        Binding="{Binding Duration}" />
                    <DataGridTextColumn Width="*"
                                        Header="状态"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        Binding="{Binding Status}" />
                    <DataGridTemplateColumn Width="88" Header="操作">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:SegmentDraft}">
                                <Button Content="删除"
                                        Width="60"
                                        Padding="10,6"
                                        Margin="0"
                                        Style="{StaticResource GhostButtonStyle}"
                                        Command="{Binding DataContext.RemoveSegmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="列表支持继续直接修改单元格；只有列表区域会出现滚动条。" />
        </Grid>

        <Border Grid.Row="4"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,1,0,0"
                Margin="0,10,0,0"
                Padding="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,6">
                    <Viewbox Width="15"
                             Height="15"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Grid Width="15" Height="15">
                            <Rectangle Margin="1.7,5.2,3.6,1.8"
                                       RadiusX="1.4"
                                       RadiusY="1.4"
                                       Stroke="{StaticResource PrimaryBrush}"
                                       StrokeThickness="1.2" />
                            <Path Data="M7.2,2.4 L12,2.4 L12,7.2"
                                  Stroke="{StaticResource PrimaryBrush}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                            <Path Data="M6,9.1 L12,3.1"
                                  Stroke="{StaticResource PrimaryBrush}"
                                  StrokeThickness="1.4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               Text="导出设置" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="输出目录" />
                    <Border Height="38"
                            Padding="12,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding OutputDirectory}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="状态" />
                    <Border Height="38"
                            Padding="12,0"
                            Background="{StaticResource MutedSurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding ExportStatus}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExportStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <Button Content="选择输出目录"
                            Width="132"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding SelectOutputDirectoryCommand}" />
                    <Button Content="开始导出"
                            Width="116"
                            Margin="0"
                            Command="{Binding ExportSegmentsCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
