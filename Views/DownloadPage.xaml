<UserControl x:Class="videoCut.Views.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:videoCut.Models"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DownloadedVideoNameTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource DataGridDisplayTextStyle}">
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="18"
                             Height="18"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center">
                        <Grid Width="18" Height="18">
                            <Border Margin="2,10,2,2"
                                    BorderBrush="{StaticResource PrimaryBrush}"
                                    BorderThickness="1.4"
                                    CornerRadius="2" />
                            <Path Data="M9,3 L9,11 M6.2,8.3 L9,11 L11.8,8.3"
                                  Stroke="{StaticResource PrimaryBrush}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Text="视频下载"
                               FontSize="22"
                               FontWeight="Bold" />
                </StackPanel>
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="输入视频地址后下载到项目内的 download 目录，下载完成后可以在列表中继续播放或进入切片流程。" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Padding="14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Style="{StaticResource LabelStyle}"
                           Text="视频地址" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Style="{StaticResource LabelStyle}"
                           Text="保存名称（可选）" />

                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,14,0"
                        Background="Transparent"
                        IsEnabled="{Binding CanEditDownloadInputs}">
                    <TextBox Margin="0"
                             Text="{Binding DownloadVideoUrl, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <Border Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,14,0"
                        Background="Transparent"
                        IsEnabled="{Binding CanEditDownloadInputs}">
                    <TextBox Margin="0"
                             Text="{Binding DownloadFileName, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Width="128"
                            VerticalAlignment="Center">
                    <Button Content="下载视频"
                            Width="128"
                            Margin="0"
                            IsEnabled="{Binding CanEditDownloadInputs}"
                            Command="{Binding DownloadVideoCommand}" />
                </StackPanel>

                <CheckBox Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,8,0,0"
                          Content="下载完成后清空输入"
                          IsChecked="{Binding ClearDownloadInputsAfterSuccess}"
                          IsEnabled="{Binding CanEditDownloadInputs}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Padding="14"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1.8*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="下载目录" />
                    <Border Height="38"
                            Padding="12,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding DownloadDirectory}" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="当前下载进度" />
                    <Border Height="38"
                            Padding="12,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ProgressBar Grid.Column="0"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding DownloadProgressValue, Mode=OneWay}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding DownloadProgressText}" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Style="{StaticResource LabelStyle}" Text="下载状态" />
                    <Border Height="38"
                            Padding="12,0"
                            Background="{StaticResource MutedSurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1">
                        <TextBlock VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding DownloadStatus}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloadStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{StaticResource MutedSurfaceBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="0,0,10,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="当前条目" />
                        <TextBlock Grid.Column="1"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding CurrentDownloadTitle}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Viewbox Width="15"
                             Height="15"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Grid Width="15" Height="15">
                            <Rectangle Margin="1.2,1.2,1.2,1.2"
                                       RadiusX="1.6"
                                       RadiusY="1.6"
                                       Stroke="{StaticResource PrimaryBrush}"
                                       StrokeThickness="1.2" />
                            <Path Data="M6,4.5 L10,7.5 L6,10.5 Z"
                                  Fill="{StaticResource PrimaryBrush}" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               VerticalAlignment="Center"
                               Text="已下载视频" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="可直接播放或进入切片" />
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Button Content="打开文件夹"
                            Width="112"
                            Margin="0,0,8,0"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding OpenDownloadFolderCommand}" />
                    <Button Content="刷新列表"
                            Width="104"
                            Margin="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource GhostButtonStyle}"
                            IsEnabled="{Binding CanRefreshDownloadedVideos}"
                            Command="{Binding RefreshDownloadedVideosCommand}" />
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="1"
                      Background="{StaticResource SurfaceBrush}"
                      ItemsSource="{Binding DownloadedVideos}"
                      IsReadOnly="True"
                      HorizontalGridLinesBrush="#FFEFF2F5">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="2.2*"
                                        Header="视频文件"
                                        ElementStyle="{StaticResource DownloadedVideoNameTextStyle}"
                                        Binding="{Binding Name}" />
                    <DataGridTextColumn Width="*"
                                        Header="文件大小"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        Binding="{Binding FileSize}" />
                    <DataGridTextColumn Width="*"
                                        Header="更新时间"
                                        ElementStyle="{StaticResource DataGridDisplayTextStyle}"
                                        Binding="{Binding ModifiedTime}" />
                    <DataGridTemplateColumn Width="136" Header="操作">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DownloadedVideoFile}">
                                <Grid Width="112" HorizontalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="播放"
                                            Width="52"
                                            Margin="0"
                                            Style="{StaticResource CompactGhostButtonStyle}"
                                            Command="{Binding DataContext.PlayDownloadedVideoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="2"
                                            Content="选择"
                                            Width="52"
                                            Margin="0"
                                            Style="{StaticResource CompactGhostButtonStyle}"
                                            IsEnabled="{Binding DataContext.CanChooseDownloadedVideo, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Command="{Binding DataContext.SelectDownloadedVideoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1"
                    Margin="1"
                    Background="#CCFFFFFF"
                    IsHitTestVisible="False">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasDownloadedVideos}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="下载目录里还没有视频" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="输入视频地址并开始下载后，视频会自动出现在列表中。" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="下载中会暂时锁定输入区和“选择”按钮，避免重复提交或切换上下文。" />
        </Grid>
    </Grid>
</UserControl>
